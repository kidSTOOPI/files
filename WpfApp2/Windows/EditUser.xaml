<Window x:Class="WpfApp2.Windows.EditUser"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp2.Windows"
        mc:Ignorable="d"
        Title="Создание пользователя" Height="303" Width="365">
    <Grid Height="334" VerticalAlignment="Top">
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="0*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="73*"/>
            <ColumnDefinition Width="33*"/>
            <ColumnDefinition Width="153*"/>
        </Grid.ColumnDefinitions>
        <Label Content="Логин" HorizontalAlignment="Left" Margin="38,34,0,0" VerticalAlignment="Top" Width="58" Grid.ColumnSpan="2"/>
        <TextBox x:Name="LoginInput" HorizontalAlignment="Left" Margin="58,42,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="171" Grid.ColumnSpan="2" Grid.Column="1"/>
        <Label Content="Пароль" HorizontalAlignment="Left" Margin="38,80,0,0" VerticalAlignment="Top" Width="58" RenderTransformOrigin="0.033,0.535" Grid.ColumnSpan="2"/>
        <PasswordBox x:Name="PasswordBox" HorizontalAlignment="Left" Margin="58,84,0,0" PasswordChar="*" VerticalAlignment="Top" Width="171" Grid.ColumnSpan="2" Grid.Column="1" RenderTransformOrigin="0.492,0.548"/>
        <Button x:Name="AddButton" Grid.Column="1" Content="Изменить" HorizontalAlignment="Left" Margin="25,238,0,0" VerticalAlignment="Top" Grid.ColumnSpan="2" Width="108" Click="AddButton_Click"/>
        <Label Content="Дата активности" HorizontalAlignment="Left" Margin="38,122,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.191,0.336" Width="108" Grid.ColumnSpan="3"/>
        <DatePicker x:Name="DatePicker" Grid.Column="2" HorizontalAlignment="Left" Margin="23,122,0,0" VerticalAlignment="Top"/>
        <Label x:Name="isChagedPassword" Content="Пароль изменён" HorizontalAlignment="Left" Margin="38,0,0,0" VerticalAlignment="Center" Grid.ColumnSpan="3" Width="104"/>
        <CheckBox x:Name="IsPasswordChangeBox" Grid.Column="2"  HorizontalAlignment="Left" Margin="23,0,0,0" VerticalAlignment="Center"/>
        <ComboBox x:Name="RoleBox" ItemsSource="{Binding}" Grid.Column="2" HorizontalAlignment="Left" Margin="23,194,0,0" VerticalAlignment="Top" Width="120"/>
        <Label x:Name="isChagedPassword_Копировать" Content="Роль" HorizontalAlignment="Left" Margin="92,192,0,0" VerticalAlignment="Top" Width="42" Grid.ColumnSpan="2"/>

    </Grid>
</Window>
