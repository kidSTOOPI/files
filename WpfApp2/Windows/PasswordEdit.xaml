<Window x:Class="WpfApp2.Windows.PasswordEdit"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp2.Windows"
        mc:Ignorable="d"
        Title="Смена пароля" Height="259" Width="343">
    <Grid>
        <Label Content="Старый пароль" HorizontalAlignment="Left" Margin="10,36,0,0" VerticalAlignment="Top" Width="109" RenderTransformOrigin="0.033,0.535"/>
        <PasswordBox x:Name="OldPasswordInput" HorizontalAlignment="Left" Margin="138,40,0,0" PasswordChar="*" VerticalAlignment="Top" Width="165"/>
        <Label Content="Новый пароль" HorizontalAlignment="Left" Margin="10,86,0,0" VerticalAlignment="Top" Width="109" RenderTransformOrigin="0.033,0.535"/>
        <PasswordBox x:Name="NewPasswordInput" HorizontalAlignment="Left" Margin="138,90,0,0" PasswordChar="*" VerticalAlignment="Top" Width="165"/>
        <Label Content="Повторение пароля" HorizontalAlignment="Left" Margin="10,122,0,0" VerticalAlignment="Top" Width="121" RenderTransformOrigin="0.033,0.535"/>
        <PasswordBox x:Name="ConfirmPasswordInput" HorizontalAlignment="Left" Margin="138,126,0,0" PasswordChar="*" VerticalAlignment="Top" Width="165"/>
        <Button x:Name="ChangePasswordButton" Content="Сменить" HorizontalAlignment="Center" Margin="0,174,0,0" VerticalAlignment="Top" Width="111" Click="ChangePasswordButton_Click"/>

    </Grid>
</Window>
