<Window x:Class="WpfApp2.Windows.Auth"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp2.Windows"
        mc:Ignorable="d"
        Title="Авторизация" Height="184" Width="313">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="73*"/>
            <ColumnDefinition Width="33*"/>
            <ColumnDefinition Width="153*"/>
        </Grid.ColumnDefinitions>
        <Label Content="Логин" HorizontalAlignment="Left" Margin="38,34,0,0" VerticalAlignment="Top" Width="58" Grid.ColumnSpan="2"/>
        <TextBox x:Name="LoginInput" HorizontalAlignment="Left" Margin="10,38,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="171" Grid.ColumnSpan="2" Grid.Column="1"/>
        <Label Content="Пароль" HorizontalAlignment="Left" Margin="34,0,0,0" VerticalAlignment="Center" Width="58" RenderTransformOrigin="0.033,0.535" Grid.ColumnSpan="2"/>
        <PasswordBox x:Name="PasswordInput" HorizontalAlignment="Left" Margin="10,0,0,0" PasswordChar="*" VerticalAlignment="Center" Width="171" Grid.ColumnSpan="2" Grid.Column="1"/>
        <Button x:Name="AuthButton" Grid.Column="1" Content="Войти" HorizontalAlignment="Left" Margin="10,115,0,0" VerticalAlignment="Top" Grid.ColumnSpan="2" Width="108" Click="AuthButton_Click"/>

    </Grid>
</Window>
