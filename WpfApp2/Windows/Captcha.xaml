<Window x:Class="WpfApp2.Windows.Captcha"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp2.Windows"
        mc:Ignorable="d"
        Title="Капча" Height="416" Width="290">
    <Grid>
        <Canvas x:Name="CaptchaContainer" Width="180" Height="175" Margin="0,54,0,205"
        HorizontalAlignment="Center">

            <Image x:Name="Img1" Source="../images/1.png" Width="78" Height="71"
           Canvas.Left="10" Canvas.Top="10" Cursor="Hand"
           RenderTransformOrigin="0.5,0.5"
           PreviewMouseLeftButtonDown="Img1_Click">
                <Image.RenderTransform>
                    <RotateTransform x:Name="Rot1" Angle="315"/>
                </Image.RenderTransform>
            </Image>

            <Image x:Name="Img2" Source="../images/2.png" Width="78" Height="71"
           Canvas.Left="92" Canvas.Top="10" Cursor="Hand"
           RenderTransformOrigin="0.5,0.5"
           PreviewMouseLeftButtonDown="Img2_Click">
                <Image.RenderTransform>
                    <RotateTransform x:Name="Rot2" Angle="135"/>
                </Image.RenderTransform>
            </Image>

            <Image x:Name="Img3" Source="../images/3.png" Width="78" Height="71"
           Canvas.Left="10" Canvas.Top="92" Cursor="Hand"
           RenderTransformOrigin="0.5,0.5"
           PreviewMouseLeftButtonDown="Img3_Click">
                <Image.RenderTransform>
                    <RotateTransform x:Name="Rot3" Angle="90"/>
                </Image.RenderTransform>
            </Image>
            <Image x:Name="Img4" Source="../images/4.png" Width="78" Height="71"
           Canvas.Left="92" Canvas.Top="92" Cursor="Hand"
           RenderTransformOrigin="0.5,0.5"
           PreviewMouseLeftButtonDown="Img4_Click">
                <Image.RenderTransform>
                    <RotateTransform x:Name="Rot4" Angle="45"/>
                </Image.RenderTransform>
            </Image>
        </Canvas>
        <Button Content="Подтвердить" HorizontalAlignment="Center"
        Width="120" Margin="0,234,0,98" Click="BtnCheck_Click"/>
    </Grid>
</Window>
